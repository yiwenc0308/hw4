<h1><%= @place["name"] %></h1>

<% if @current_user %>
  <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-outline-dark mb-4">New Post</a>
<% end %>

<div class="row">
  <% for entry in @entries %>
    <div class="col-lg-4 col-md-6 mb-4">
      <h3><%= entry["title"] %></h3>
      <p class="text-muted mb-1"><%= entry["occurred_on"] %></p>
      <% if entry.image.attached? %>
        <img src="<%= url_for(entry.image) %>" class="img-fluid mb-2" style="width:100%;">
      <% else %>
        <div class="bg-light border mb-2" style="position:relative;padding-bottom:75%;">
          <svg style="position:absolute;top:0;left:0;width:100%;height:100%;" xmlns="http://www.w3.org/2000/svg">
            <line x1="0" y1="0" x2="100%" y2="100%" stroke="#aaa"/>
            <line x1="100%" y1="0" x2="0" y2="100%" stroke="#aaa"/>
          </svg>
        </div>
      <% end %>
      <p><%= entry["description"] %></p>
    </div>
  <% end %>
</div>

<a href="/places" class="btn btn-secondary mt-2">Back to All Places</a>
